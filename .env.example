NODE_ENV=development
PORT=4000

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/restaurant_pos?schema=public"

# Generate strong secrets, e.g.: openssl rand -base64 48
JWT_ACCESS_SECRET=replace-with-a-random-32-plus-character-secret
JWT_REFRESH_SECRET=replace-with-a-different-random-32-plus-character-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:5173

BCRYPT_SALT_ROUNDS=12

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300

RESTAURANT_OPEN_HOUR=12
RESTAURANT_CLOSE_HOUR=23
TAX_RATE_PERCENT=5
